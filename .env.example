# ═══════════════════════════════════════════════
#  SoundWeave Environment Variables Template
#  Copy to .env and fill in your real values
# ═══════════════════════════════════════════════

# ── Backend ──────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ORCHESTRATION_URL=http://localhost:8000
DATABASE_URL=postgresql://soundweave:soundweave@localhost:5432/soundweave
REDIS_URL=redis://localhost:6379

# ── IBM Watsonx / Granite ─────────────────────
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# ── ElevenLabs ────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Freesound ─────────────────────────────────
FREESOUND_API_KEY=your_freesound_api_key_here

# ── AWS S3 / Cloudflare R2 ────────────────────
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=us-east-1
S3_BUCKET=soundweave-audio
S3_PUBLIC_URL=https://soundweave-audio.s3.amazonaws.com
# S3_ENDPOINT=https://your-r2-endpoint  # Uncomment for Cloudflare R2
